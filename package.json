    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import": "^2.30.0",
    "lefthook": "^2.0.0",
    "prettier": "^3.0.0",

    "discord.js": "^14.0.0",
    "mongodb": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-import": "^2.30.0",
    "lefthook": "^2.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.6.0"
  }
